---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, tags, excerpt, description } = post.data;
const summary = excerpt ?? description;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/posts/${post.slug}/`} class="post-card">
  <div class="post-card-body">
    <p class="post-card-date">{formattedDate}</p>
    <h2 class="post-card-title">{title}</h2>
    {summary && <p class="post-card-excerpt">{summary}</p>}
    {tags && tags.length > 0 && (
      <div class="post-card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="post-tag">#{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
